---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MeridianArc from '../components/MeridianArc.astro';
import { getSiteData } from '../lib/notion';

const { items, narratives } = await getSiteData();

// Featured plates — up to 3 for the vitrine row
const featured = items.filter((i) => i.featured && i.primaryImage).slice(0, 3);
const plates = featured.length >= 3
  ? featured
  : [...featured, ...items.filter((i) => i.primaryImage && !featured.includes(i))].slice(0, 3);

const publishedNarratives = narratives
  .filter((n) => n.publishStatus === 'Published')
  .sort((a, b) => a.displayOrder - b.displayOrder)
  .slice(0, 2);

const years = items.map((i) => i.year).filter((y): y is number => y !== null);
const minYear = years.length ? Math.min(...years) : null;
const maxYear = years.length ? Math.max(...years) : null;

const ROMAN = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII'];

function plateLabel(item: (typeof items)[number]): string {
  const parts: string[] = [];
  if (item.year !== null) parts.push(item.dateDetail || String(item.year));
  if (item.originCountry) parts.push(item.originCountry);
  return parts.join(' · ');
}

const description = `The Meridian — a private archive of ${items.length} antiques and historical objects spanning ${minYear ?? ''} to ${maxYear ?? ''}: Sri Lanka and Ceylon across every century, and the instruments by which mankind learned to measure, record, calculate, and see. Maps, scientific instruments, rare books, photographs, and documents, each verified and documented.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'The Meridian',
    alternateName: 'The Meridian Archive',
    url: 'https://meridian.yulan.me',
    description,
    inLanguage: 'en',
    publisher: { '@id': 'https://meridian.yulan.me/#curator' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': 'https://meridian.yulan.me/#curator',
    name: 'Yulan Galagoda',
    url: 'https://yulan.me',
    email: 'mailto:yulangalagoda1@gmail.com',
    jobTitle: 'Curator',
    knowsAbout: [
      'Antiques',
      'Sri Lanka history',
      'Ceylon colonial history',
      'Scientific instruments',
      'Antiquarian books',
      'Early photography',
      'Cartography',
      'Provenance research',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Collection',
    name: 'The Meridian Collection',
    url: 'https://meridian.yulan.me/collection',
    description: `${items.length} antiques and historical objects, ${minYear ?? ''}–${maxYear ?? ''}.`,
    collectionSize: items.length,
  },
];
---

<Base title="The Meridian" description={description} jsonLd={jsonLd}>
  <Header />

  <main>
    <!-- ── Hero ──────────────────────────────────────────────────────────── -->
    <section class="hero" aria-label="Introduction">
      <div class="container">
        <h1 class="hero__title">The Meridian</h1>
        <p class="hero__kicker">A private archive of antiques &amp; historical objects</p>
      </div>
    </section>

    <!-- ── Epigraph ──────────────────────────────────────────────────────── -->
    <section class="epigraph" aria-label="Epigraph">
      <div class="epigraph__orn" aria-hidden="true">✦</div>
      <p class="epigraph__pali" lang="pi">Vayadhammā saṅkhārā</p>
      <p class="epigraph__trans">All conditioned things are subject to decay.</p>
      <p class="epigraph__source">
        — The Buddha's final words ·
        <a href="https://suttacentral.net/dn16" target="_blank" rel="noopener">Mahāparinibbāna Sutta, Dīgha Nikāya 16</a>
      </p>
    </section>

    <!-- ── Rotating meridian line ────────────────────────────────────────── -->
    <MeridianArc items={items} />

    <!-- ── Vitrines ──────────────────────────────────────────────────────── -->
    {plates.length > 0 && (
      <section class="section-gap" aria-label="Selected objects">
        <div class="container">
          <div class="plates-head">
            <h2>In the vitrines</h2>
            <div class="plates-head__rule" aria-hidden="true"></div>
            <a href="/collection">Full collection →</a>
          </div>
          <div class="plate-grid">
            {plates.map((item) => (
              <a class="plate reveal" href={`/collection/${item.slug}`}>
                <div class="plate__ph">
                  <img
                    src={item.primaryImage}
                    alt={item.imageAltText || item.name}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <p class="plate__num">{plateLabel(item)}</p>
                <h3 class="plate__name">{item.name}</h3>
                {item.shortDescription && <p class="plate__meta">{item.shortDescription}</p>}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── Narratives teaser ─────────────────────────────────────────────── -->
    {publishedNarratives.length > 0 && (
      <section class="section-gap--sm" aria-label="Narratives" style="padding-bottom: var(--section-y);">
        <div class="container">
          <div class="plates-head">
            <h2>Narratives</h2>
            <div class="plates-head__rule" aria-hidden="true"></div>
            <a href="/narratives">All narratives →</a>
          </div>
          <div class="narr-grid">
            {publishedNarratives.map((n, idx) => (
              <a class="narr-card reveal" href={`/narratives/${n.slug}`}>
                <p class="narr-card__kicker">Narrative · {ROMAN[idx] ?? idx + 1}</p>
                <h3 class="narr-card__name">{n.name}</h3>
                {n.premise && <p class="narr-card__premise">{n.premise}</p>}
                <div class="narr-card__objects">
                  <span class="narr-card__count">{n.itemIds.length} objects, one story →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer itemCount={items.length} />
</Base>
