---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ItemCard from '../components/ItemCard.astro';
import Timeline from '../components/Timeline.astro';
import { getSiteData } from '../lib/notion';

const { items, categories } = await getSiteData();
const featured = items.filter((i) => i.featured).slice(0, 6);
const displayItems = featured.length > 0 ? featured : items.slice(0, 6);
---

<Base
  title="The Meridian"
  description="A curated archive of antiques and historical objects by YG."
>
  <Header />

  <main>
    <!-- Homepage hero split -->
    <section class="home-split">
      <div class="container">
        <div class="home-split__inner">

          <!-- Left: intro + featured -->
          <div class="home-split__left">
            <div class="home-intro">
              <p class="eyebrow eyebrow--accent">The Meridian</p>
              <h1 class="home-intro__title">A private archive of antiques and historical objects.</h1>
              <p class="home-intro__body">
                Objects acquired, studied, and documented. Each one a point on the long line
                from the first tools to the present.
              </p>
              <a href="/collection" class="home-intro__link">
                Browse the collection
                <svg viewBox="0 0 16 10" width="14" height="9" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M1 5h14M10 1l5 4-5 4"/>
                </svg>
              </a>
            </div>

            {displayItems.length > 0 && (
              <div class="home-featured">
                <div class="home-section-row">
                  <h2 class="home-section-title eyebrow">Featured</h2>
                  <a href="/collection" class="home-section-link eyebrow">All objects</a>
                </div>
                <div class="item-grid item-grid--featured">
                  {displayItems.map((item, i) => (
                    <ItemCard item={item} eager={i < 2} />
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Right: timeline (hidden on mobile) -->
          <aside class="home-split__right" aria-label="Collection timeline">
            <div class="home-timeline-panel">
              <Timeline items={items} />
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- Categories -->
    {categories.length > 0 && (
      <section class="section-gap--sm">
        <div class="container">
          <div class="home-section-row">
            <h2 class="home-section-title eyebrow">Browse by category</h2>
          </div>
          <div class="cat-grid">
            {categories.map((cat) => (
              <a href={`/categories/${cat.slug}`} class="cat-card reveal">
                {cat.coverImage ? (
                  <div class="cat-card__image">
                    <img src={cat.coverImage} alt={cat.name} loading="lazy" decoding="async" />
                  </div>
                ) : (
                  <div class="cat-card__image cat-card__image--empty">
                    <span class="cat-card__icon">{cat.icon}</span>
                  </div>
                )}
                <div class="cat-card__body">
                  <span class="cat-card__name">{cat.name}</span>
                  {cat.description && (
                    <span class="cat-card__desc">{cat.description}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer itemCount={items.length} />
</Base>

<style>
  /* ── Home split layout ─────────────────────────────────────────────────────── */
  .home-split {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .home-split__inner {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  /* Intro block */
  .home-intro {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .home-intro__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin-top: var(--sp-4);
    max-width: 22ch;
  }

  .home-intro__body {
    margin-top: var(--sp-5);
    font-size: var(--text-base);
    color: var(--ink-mute);
    line-height: var(--lh-loose);
    max-width: 48ch;
  }

  .home-intro__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--oxblood);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .home-intro__link:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-3) + 4px);
  }

  /* Section rows */
  .home-section-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
  }

  .home-section-title {
    color: var(--ink-mute);
    letter-spacing: var(--tracking-caps);
  }

  .home-section-link {
    font-size: 0.65rem;
    color: var(--ink-faint);
    text-decoration: none;
    letter-spacing: var(--tracking-caps);
    transition: color var(--dur-base) var(--ease-io);
  }
  .home-section-link:hover { color: var(--ink-mute); }

  /* Featured grid — 2 cols on the left panel */
  .item-grid--featured {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-5);
  }

  /* Timeline panel */
  .home-split__right {
    position: sticky;
    top: calc(4rem + var(--sp-8));
    height: calc(100vh - 6rem);
    max-height: 560px;
    min-height: 420px;
  }

  .home-timeline-panel {
    height: 100%;
    padding: var(--sp-6);
    border: 1px solid var(--stone-3);
    background: var(--stone);
  }

  /* Category grid */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-4);
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--stone-3);
    overflow: hidden;
    transition:
      border-color var(--dur-slow) var(--ease-io),
      box-shadow var(--dur-slow) var(--ease-io);
  }

  .cat-card:hover {
    border-color: var(--stone-4);
    box-shadow: var(--shadow-card);
    color: inherit;
  }

  .cat-card:hover .cat-card__image img {
    transform: scale(1.02);
  }

  .cat-card__image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--stone-2);
  }

  .cat-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-luxury) var(--ease-out);
  }

  .cat-card__image--empty {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cat-card__icon {
    font-size: 2rem;
    opacity: 0.4;
  }

  .cat-card__body {
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .cat-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
  }

  .cat-card__desc {
    font-size: var(--text-xs);
    color: var(--ink-mute);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ───────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .home-split__inner {
      grid-template-columns: 1fr;
    }
    .home-split__right {
      display: none;
    }
    .item-grid--featured {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
  }

  @media (max-width: 640px) {
    .item-grid--featured {
      grid-template-columns: 1fr;
    }
  }
</style>
