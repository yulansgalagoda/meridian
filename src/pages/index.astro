---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ItemCard from '../components/ItemCard.astro';
import Timeline from '../components/Timeline.astro';
import { getSiteData } from '../lib/notion';

const { items, categories } = await getSiteData();

// Featured items (up to 4 for a 2×2 grid)
const featured = items.filter((i) => i.featured).slice(0, 4);
const displayItems = featured.length > 0 ? featured : items.slice(0, 4);

// Stats
type ItemWithYear = (typeof items)[number] & { year: number };
const yearItems = items.filter((i): i is ItemWithYear => i.year !== null);
const oldestYear  = yearItems.length ? Math.min(...yearItems.map(i => i.year)) : null;
const newestYear  = yearItems.length ? Math.max(...yearItems.map(i => i.year)) : null;
const originCount = new Set(items.map(i => i.originCountry).filter(Boolean)).size;
const latestAdded = items.length
  ? [...items].sort((a, b) => b.itemId - a.itemId)[0]
  : null;

function formatYear(y: number): string {
  return y < 0 ? `${Math.abs(y)} BCE` : String(y);
}

// Items per category
const catCounts = new Map<string, number>();
for (const item of items) {
  if (item.categorySlug) catCounts.set(item.categorySlug, (catCounts.get(item.categorySlug) ?? 0) + 1);
}
---

<Base
  title="The Meridian"
  description="A curated archive of antiques and historical objects by YG."
>
  <Header />

  <main>
    <div class="container home">

      <!-- ── Row 1: Introduction + Timeline ───────────────────────────────── -->
      <section class="hrow" aria-label="Introduction">
        <div class="hrow__left">
          <p class="eyebrow eyebrow--accent">The Meridian</p>
          <h1 class="intro-title">A private archive of antiques and historical objects.</h1>
          <p class="intro-body">
            Objects acquired, studied, and documented. Each one a fixed point
            on the long line from the first tools to the present day.
          </p>
          <a href="/collection" class="text-cta">
            Browse the collection
            <svg viewBox="0 0 16 10" width="13" height="8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 5h14M10 1l5 4-5 4"/>
            </svg>
          </a>
        </div>
        <aside class="hrow__right hrow__right--timeline" aria-label="Collection timeline">
          <Timeline items={items} />
        </aside>
      </section>

      <!-- ── Row 2: Why I Collect + Stats ─────────────────────────────────── -->
      <section class="hrow" aria-label="Why I collect">
        <div class="hrow__left">
          <p class="eyebrow eyebrow--muted">Why I collect</p>
          <blockquote class="why-quote">
            Objects do not explain themselves. Each one arrived from another time,
            passed through hands I cannot count, survived neglect or care or accident.
            I collect not to possess but to understand: what people made, why, and how long it lasted.
          </blockquote>
          <a href="/about" class="text-cta">
            About this archive
            <svg viewBox="0 0 16 10" width="13" height="8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 5h14M10 1l5 4-5 4"/>
            </svg>
          </a>
        </div>
        <div class="hrow__right">
          <p class="hrow__right-label eyebrow eyebrow--muted">The collection</p>
          <div class="stats-grid">
            <div class="stat">
              <span class="stat__val">{items.length}</span>
              <span class="stat__label">Objects</span>
            </div>
            <div class="stat">
              <span class="stat__val">{categories.length}</span>
              <span class="stat__label">Categories</span>
            </div>
            {oldestYear !== null && (
              <div class="stat">
                <span class="stat__val">{formatYear(oldestYear)}</span>
                <span class="stat__label">Oldest dated</span>
              </div>
            )}
            {newestYear !== null && (
              <div class="stat">
                <span class="stat__val">{formatYear(newestYear)}</span>
                <span class="stat__label">Most recent dated</span>
              </div>
            )}
            {originCount > 0 && (
              <div class="stat">
                <span class="stat__val">{originCount}</span>
                <span class="stat__label">Origins</span>
              </div>
            )}
            {latestAdded && (
              <div class="stat stat--wide">
                <span class="stat__val stat__val--name">{latestAdded.name}</span>
                <span class="stat__label">Latest acquisition</span>
              </div>
            )}
          </div>
        </div>
      </section>

      <!-- ── Row 3: Featured items + Categories ───────────────────────────── -->
      {(displayItems.length > 0 || categories.length > 0) && (
        <section class="hrow" aria-label="Featured and categories">
          {displayItems.length > 0 && (
            <div class="hrow__left">
              <div class="row-header">
                <h2 class="row-header__title eyebrow">Selected objects</h2>
                <a href="/collection" class="row-header__link eyebrow">All objects</a>
              </div>
              <div class="item-grid feat-grid">
                {displayItems.map((item, i) => (
                  <ItemCard item={item} eager={i < 2} />
                ))}
              </div>
            </div>
          )}
          {categories.length > 0 && (
            <div class="hrow__right">
              <div class="row-header">
                <h2 class="row-header__title eyebrow">Categories</h2>
              </div>
              <ul class="cat-list">
                {categories.map((cat) => (
                  <li>
                    <a href={`/categories/${cat.slug}`} class="cat-list-item">
                      <span class="cat-list-item__left">
                        {cat.icon && <span class="cat-list-item__icon" aria-hidden="true">{cat.icon}</span>}
                        <span class="cat-list-item__name">{cat.name}</span>
                      </span>
                      <span class="cat-list-item__count">
                        {catCounts.get(cat.slug) ?? 0}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>
      )}

      <!-- ── End note ──────────────────────────────────────────────────────── -->
      <div class="endnote">
        <p class="endnote__text">
          The archive grows slowly, by design. New objects are added as they find their way here.
        </p>
        <a href="/about" class="text-cta">
          Read about this collection
          <svg viewBox="0 0 16 10" width="13" height="8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 5h14M10 1l5 4-5 4"/>
          </svg>
        </a>
      </div>

    </div>
  </main>

  <Footer itemCount={items.length} />
</Base>

<style>
  /* ── Home container ───────────────────────────────────────────────────────── */
  .home {
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* ── Shared row layout ────────────────────────────────────────────────────── */
  .hrow {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 0;
    padding-block: clamp(3rem, 5vw, 4.5rem);
    border-top: 1px solid var(--stone-3);
  }

  .hrow__left {
    padding-right: clamp(2rem, 4vw, 3.5rem);
    border-right: 1px solid var(--stone-3);
  }

  .hrow__right {
    padding-left: clamp(2rem, 4vw, 3rem);
  }

  .hrow__right-label {
    margin-bottom: var(--sp-6);
  }

  /* Timeline panel — fixed height so SVG has room to scale up */
  .hrow__right--timeline {
    height: 580px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Row 1: Introduction ──────────────────────────────────────────────────── */
  .intro-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-top: var(--sp-5);
    max-width: 20ch;
  }

  .intro-body {
    margin-top: clamp(1.25rem, 2vw, 1.75rem);
    font-size: var(--text-base);
    color: var(--ink-mute);
    line-height: 1.75;
    max-width: 52ch;
  }

  /* ── Shared CTA link ──────────────────────────────────────────────────────── */
  .text-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: clamp(1.25rem, 2.5vw, 2rem);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--oxblood);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .text-cta:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-3) + 5px);
  }

  /* ── Row 2: Why I collect ─────────────────────────────────────────────────── */
  .why-quote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: var(--sp-5) 0 var(--sp-6);
    padding: 0;
    border: none;
    max-width: 42ch;
  }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-1);
  }

  .stat {
    padding: var(--sp-5) var(--sp-4);
    border: 1px solid var(--stone-3);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .stat--wide {
    grid-column: span 2;
  }

  .stat__val {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 2.5vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
  }

  .stat__val--name {
    font-size: clamp(1rem, 1.5vw, 1.3rem);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .stat__label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* ── Row 3: Row header ────────────────────────────────────────────────────── */
  .row-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
  }

  .row-header__title {
    color: var(--ink-mute);
  }

  .row-header__link {
    font-size: 0.65rem;
    color: var(--ink-faint);
    text-decoration: none;
    letter-spacing: var(--tracking-caps);
    transition: color var(--dur-base) var(--ease-io);
  }

  .row-header__link:hover {
    color: var(--ink-mute);
  }

  /* Featured grid — 2 columns */
  .feat-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-4);
  }

  /* ── Category list ────────────────────────────────────────────────────────── */
  .cat-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .cat-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--stone-3);
    text-decoration: none;
    color: var(--ink);
    gap: var(--sp-3);
    transition: color var(--dur-base) var(--ease-io);
  }

  .cat-list-item:first-child {
    border-top: 1px solid var(--stone-3);
  }

  .cat-list-item:hover {
    color: var(--oxblood);
  }

  .cat-list-item__left {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    min-width: 0;
  }

  .cat-list-item__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    width: 1.5rem;
    text-align: center;
  }

  .cat-list-item__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cat-list-item__count {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    color: var(--ink-faint);
    flex-shrink: 0;
  }

  /* ── End note ─────────────────────────────────────────────────────────────── */
  .endnote {
    padding-block: clamp(3rem, 5vw, 4.5rem);
    border-top: 1px solid var(--stone-3);
    display: flex;
    align-items: baseline;
    gap: clamp(2rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .endnote__text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink-mute);
    line-height: 1.5;
    max-width: 54ch;
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hrow {
      grid-template-columns: 1fr;
    }

    .hrow__left {
      border-right: none;
      border-bottom: 1px solid var(--stone-3);
      padding-right: 0;
      padding-bottom: clamp(2rem, 4vw, 3rem);
    }

    .hrow__right {
      padding-left: 0;
      padding-top: clamp(2rem, 4vw, 3rem);
    }

    /* Hide timeline on mobile */
    .hrow__right--timeline {
      display: none;
    }

    .feat-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .endnote {
      flex-direction: column;
      gap: var(--sp-6);
    }
  }

  @media (max-width: 560px) {
    .feat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
