---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ItemCard from '../components/ItemCard.astro';
import Timeline from '../components/Timeline.astro';
import { getSiteData } from '../lib/notion';

const { items, categories } = await getSiteData();
const featured = items.filter((i) => i.featured).slice(0, 6);
const displayItems = featured.length > 0 ? featured : items.slice(0, 6);
---

<Base
  title="The Meridian"
  description="A curated archive of antiques and historical objects by YG."
>
  <Header />

  <main class="home">

    <!-- ── Section 1: Hero + Timeline ─────────────────────────────────────── -->
    <section class="hero" id="s1" aria-label="Introduction">
      <div class="hero__left">
        <p class="hero__eyebrow eyebrow eyebrow--accent">The Meridian</p>
        <h1 class="hero__title">A private archive of antiques and historical objects.</h1>
        <p class="hero__body">
          Objects acquired, studied, and documented. Each one a point on the long line
          from the first tools to the present day.
        </p>
        <a href="/collection" class="hero__link">
          Browse the collection
          <svg viewBox="0 0 16 10" width="14" height="9" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 5h14M10 1l5 4-5 4"/>
          </svg>
        </a>
        <a href="#s2" class="hero__scroll-hint" aria-label="Scroll to next section">
          <svg viewBox="0 0 14 8" width="14" height="8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M1 1l6 6 6-6"/>
          </svg>
        </a>
      </div>

      <aside class="hero__right" aria-label="Collection timeline">
        <Timeline items={items} />
      </aside>
    </section>

    <!-- ── Section 2: Why I Collect + Featured ────────────────────────────── -->
    <section class="why-section" id="s2" aria-label="Why I collect">
      <div class="why-section__inner">
        <div class="why-block reveal">
          <p class="eyebrow eyebrow--muted">Why I collect</p>
          <blockquote class="why-quote">
            Objects do not explain themselves. Each one arrived here from another time,
            passed through hands I cannot count, survived neglect or care or accident.
            I collect not to possess but to understand: what people made, why they made it,
            and how long it lasted.
          </blockquote>
          <a href="/about" class="why-link">
            Read more about this archive
            <svg viewBox="0 0 16 10" width="12" height="8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 5h14M10 1l5 4-5 4"/>
            </svg>
          </a>
        </div>

        {displayItems.length > 0 && (
          <div class="featured-block">
            <div class="home-section-row">
              <h2 class="home-section-title eyebrow">Selected objects</h2>
              <a href="/collection" class="home-section-link eyebrow">View all</a>
            </div>
            <div class="item-grid featured-grid">
              {displayItems.map((item, i) => (
                <ItemCard item={item} eager={i < 3} />
              ))}
            </div>
          </div>
        )}

        <a href="#s3" class="section-scroll-hint" aria-label="Scroll to categories">
          <svg viewBox="0 0 14 8" width="14" height="8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M1 1l6 6 6-6"/>
          </svg>
        </a>
      </div>
    </section>

    <!-- ── Section 3: Categories ───────────────────────────────────────────── -->
    {categories.length > 0 && (
      <section class="cat-section" id="s3" aria-label="Browse by category">
        <div class="cat-section__inner">
          <div class="home-section-row reveal">
            <h2 class="cat-section__heading">Browse by category</h2>
          </div>
          <div class="cat-grid">
            {categories.map((cat, i) => (
              <a href={`/categories/${cat.slug}`} class="cat-card reveal" style={`transition-delay: ${i * 50}ms`}>
                {cat.coverImage ? (
                  <div class="cat-card__image">
                    <img src={cat.coverImage} alt={cat.name} loading="lazy" decoding="async" />
                  </div>
                ) : (
                  <div class="cat-card__image cat-card__image--empty">
                    <span class="cat-card__icon">{cat.icon}</span>
                  </div>
                )}
                <div class="cat-card__body">
                  <span class="cat-card__name">{cat.name}</span>
                  {cat.description && (
                    <span class="cat-card__desc">{cat.description}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer itemCount={items.length} />
</Base>

<style>
  .home {
    overflow-x: hidden;
  }

  /* ── Section 1: Hero ──────────────────────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 420px;
    height: calc(100svh - var(--header-h, 72px));
    min-height: 560px;
  }

  .hero__left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2.5rem, 5vw, 5rem) clamp(2rem, 4vw, 4rem) clamp(2.5rem, 5vw, 5rem) clamp(2rem, 6vw, 6rem);
    position: relative;
  }

  .hero__eyebrow {
    margin-bottom: var(--sp-5);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.5vw, 5.5rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 16ch;
  }

  .hero__body {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: var(--ink-mute);
    line-height: 1.7;
    max-width: 44ch;
  }

  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--oxblood);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .hero__link:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-3) + 5px);
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: clamp(1.5rem, 3vw, 2.5rem);
    left: clamp(2rem, 6vw, 6rem);
    color: var(--ink-faint);
    text-decoration: none;
    display: flex;
    align-items: center;
    animation: bounce-hint 2.5s ease-in-out infinite;
    transition: color var(--dur-base) var(--ease-io);
  }

  .hero__scroll-hint:hover {
    color: var(--ink-mute);
  }

  @keyframes bounce-hint {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  /* Timeline panel — full height */
  .hero__right {
    height: 100%;
    border-left: 1px solid var(--stone-3);
    padding: clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 2.5vw, 2.5rem);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Section 2: Why I Collect ────────────────────────────────────────────── */
  .why-section {
    min-height: 100svh;
    border-top: 1px solid var(--stone-3);
    position: relative;
  }

  .why-section__inner {
    max-width: var(--container-max, 1280px);
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 5rem);
    position: relative;
  }

  .why-block {
    max-width: 720px;
    margin-bottom: clamp(4rem, 7vw, 7rem);
  }

  .why-quote {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: var(--sp-5) 0 var(--sp-7);
    padding: 0;
    border: none;
  }

  .why-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--oxblood);
    text-decoration: none;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .why-link:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-2) + 4px);
  }

  /* Featured grid */
  .featured-block {
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .featured-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* Section scroll hints */
  .section-scroll-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-faint);
    text-decoration: none;
    width: 2.5rem;
    height: 2.5rem;
    margin: 0 auto;
    animation: bounce-hint 2.5s ease-in-out infinite;
    transition: color var(--dur-base) var(--ease-io);
  }

  .section-scroll-hint:hover {
    color: var(--ink-mute);
  }

  /* Section row header */
  .home-section-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
  }

  .home-section-title {
    color: var(--ink-mute);
    letter-spacing: var(--tracking-caps);
  }

  .home-section-link {
    font-size: 0.65rem;
    color: var(--ink-faint);
    text-decoration: none;
    letter-spacing: var(--tracking-caps);
    transition: color var(--dur-base) var(--ease-io);
  }

  .home-section-link:hover {
    color: var(--ink-mute);
  }

  /* ── Section 3: Categories ───────────────────────────────────────────────── */
  .cat-section {
    min-height: 80svh;
    border-top: 1px solid var(--stone-3);
    background: var(--stone-2);
  }

  .cat-section__inner {
    max-width: var(--container-max, 1280px);
    margin: 0 auto;
    padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 5vw, 5rem);
  }

  .cat-section__heading {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  /* Category grid */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--sp-4);
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--stone-3);
    background: var(--stone);
    overflow: hidden;
    transition:
      border-color var(--dur-slow) var(--ease-io),
      box-shadow var(--dur-slow) var(--ease-io);
  }

  .cat-card:hover {
    border-color: var(--stone-4);
    box-shadow: var(--shadow-card);
    color: inherit;
  }

  .cat-card:hover .cat-card__image img {
    transform: scale(1.02);
  }

  .cat-card__image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--stone-2);
  }

  .cat-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-luxury) var(--ease-out);
  }

  .cat-card__image--empty {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cat-card__icon {
    font-size: 2rem;
    opacity: 0.4;
  }

  .cat-card__body {
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .cat-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
  }

  .cat-card__desc {
    font-size: var(--text-xs);
    color: var(--ink-mute);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 100svh;
    }

    .hero__left {
      padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
      justify-content: flex-start;
      padding-top: clamp(4rem, 10vw, 7rem);
    }

    .hero__right {
      display: none;
    }

    .hero__scroll-hint {
      position: static;
      margin-top: clamp(2.5rem, 6vw, 4rem);
    }

    .featured-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 400px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
