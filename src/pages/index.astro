---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ItemCard from '../components/ItemCard.astro';
import Timeline from '../components/Timeline.astro';
import { getSiteData } from '../lib/notion';

const { items, categories } = await getSiteData();
const featured = items.filter((i) => i.featured).slice(0, 6);
const displayItems = featured.length > 0 ? featured : items.slice(0, 6);
---

<Base
  title="The Meridian"
  description="A curated archive of antiques and historical objects by YG."
>
  <Header />

  <main>

    <!-- ── Section 1: Hero ─────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="container hero__grid">

        <div class="hero__text">
          <p class="eyebrow eyebrow--accent hero__eyebrow">The Meridian</p>
          <h1 class="hero__title">A private archive of antiques and historical objects.</h1>
          <p class="hero__body">
            Objects acquired, studied, and documented. Each one a fixed point
            on the long line from the first tools to the present day.
          </p>
          <a href="/collection" class="hero__cta">
            Browse the collection
            <svg viewBox="0 0 16 10" width="13" height="8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 5h14M10 1l5 4-5 4"/>
            </svg>
          </a>
        </div>

        <aside class="hero__timeline" aria-label="Collection timeline">
          <Timeline items={items} />
        </aside>

      </div>
    </section>

    <!-- ── Section 2: Why I Collect + Featured ───────────────────────────── -->
    <section class="why-section">
      <div class="container">

        <div class="why-block reveal">
          <p class="eyebrow eyebrow--muted">Why I collect</p>
          <blockquote class="why-quote">
            Objects do not explain themselves. Each one arrived from another time,
            passed through hands I cannot count, survived neglect or care or accident.
            I collect not to possess but to understand: what people made, why, and how long it lasted.
          </blockquote>
          <a href="/about" class="why-link">
            About this archive
            <svg viewBox="0 0 16 10" width="11" height="7" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 5h14M10 1l5 4-5 4"/>
            </svg>
          </a>
        </div>

        {displayItems.length > 0 && (
          <div class="featured-block">
            <div class="section-row">
              <h2 class="section-row__label eyebrow">Selected objects</h2>
              <a href="/collection" class="section-row__link eyebrow">View all</a>
            </div>
            <div class="item-grid featured-grid">
              {displayItems.map((item, i) => (
                <ItemCard item={item} eager={i < 3} />
              ))}
            </div>
          </div>
        )}

      </div>
    </section>

    <!-- ── Section 3: Categories ──────────────────────────────────────────── -->
    {categories.length > 0 && (
      <section class="cat-section">
        <div class="container">
          <div class="section-row">
            <h2 class="cat-section__heading">Browse by category</h2>
          </div>
          <div class="cat-grid">
            {categories.map((cat) => (
              <a href={`/categories/${cat.slug}`} class="cat-card">
                {cat.coverImage ? (
                  <div class="cat-card__image">
                    <img src={cat.coverImage} alt={cat.name} loading="lazy" decoding="async" />
                  </div>
                ) : (
                  <div class="cat-card__image cat-card__image--empty">
                    <span class="cat-card__icon">{cat.icon}</span>
                  </div>
                )}
                <div class="cat-card__body">
                  <span class="cat-card__name">{cat.name}</span>
                  {cat.description && (
                    <span class="cat-card__desc">{cat.description}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer itemCount={items.length} />
</Base>

<style>
  /* ── Section 1: Hero ──────────────────────────────────────────────────────── */
  .hero {
    height: calc(100svh - 57px); /* 57px = header height */
    min-height: 520px;
    max-height: 900px;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 0;
    height: 100%;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--sp-12);
    padding-right: clamp(var(--sp-8), 5vw, var(--sp-24));
    border-right: 1px solid var(--stone-3);
  }

  .hero__eyebrow {
    margin-bottom: var(--sp-5);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 18ch;
  }

  .hero__body {
    margin-top: clamp(1.25rem, 2.5vw, 2rem);
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    color: var(--ink-mute);
    line-height: 1.75;
    max-width: 48ch;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--oxblood);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .hero__cta:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-3) + 5px);
  }

  /* Timeline panel — fills the right column height */
  .hero__timeline {
    height: 100%;
    padding: clamp(var(--sp-6), 3vw, var(--sp-10)) clamp(var(--sp-6), 3vw, var(--sp-8));
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Section 2: Why I Collect ────────────────────────────────────────────── */
  .why-section {
    padding-block: clamp(4rem, 7vw, 6rem);
    border-top: 1px solid var(--stone-3);
  }

  .why-block {
    max-width: 680px;
    margin-bottom: clamp(3.5rem, 6vw, 5rem);
  }

  .why-quote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2.5rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: var(--sp-5) 0 var(--sp-6);
    padding: 0;
    border: none;
  }

  .why-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--oxblood);
    text-decoration: none;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .why-link:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-2) + 4px);
  }

  /* ── Section rows ────────────────────────────────────────────────────────── */
  .section-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
  }

  .section-row__label {
    color: var(--ink-mute);
  }

  .section-row__link {
    font-size: 0.65rem;
    color: var(--ink-faint);
    text-decoration: none;
    letter-spacing: var(--tracking-caps);
    transition: color var(--dur-base) var(--ease-io);
  }

  .section-row__link:hover {
    color: var(--ink-mute);
  }

  /* Featured grid — 3 columns */
  .featured-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* ── Section 3: Categories ───────────────────────────────────────────────── */
  .cat-section {
    padding-block: clamp(4rem, 7vw, 6rem);
    border-top: 1px solid var(--stone-3);
    background: var(--stone-2);
  }

  .cat-section__heading {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-4);
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--stone-3);
    background: var(--stone);
    overflow: hidden;
    transition:
      border-color var(--dur-slow) var(--ease-io),
      box-shadow var(--dur-slow) var(--ease-io);
  }

  .cat-card:hover {
    border-color: var(--stone-4);
    box-shadow: var(--shadow-card);
    color: inherit;
  }

  .cat-card:hover .cat-card__image img {
    transform: scale(1.02);
  }

  .cat-card__image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--stone-2);
  }

  .cat-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-luxury) var(--ease-out);
  }

  .cat-card__image--empty {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cat-card__icon {
    font-size: 2rem;
    opacity: 0.4;
  }

  .cat-card__body {
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .cat-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
  }

  .cat-card__desc {
    font-size: var(--text-xs);
    color: var(--ink-mute);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */

  /* Tablet: narrow the timeline */
  @media (max-width: 1100px) {
    .hero__grid {
      grid-template-columns: 1fr 320px;
    }
  }

  /* Mobile: stack and hide timeline */
  @media (max-width: 800px) {
    .hero {
      height: auto;
      min-height: calc(100svh - 57px);
      max-height: none;
    }

    .hero__grid {
      grid-template-columns: 1fr;
      height: auto;
    }

    .hero__text {
      border-right: none;
      border-bottom: 1px solid var(--stone-3);
      padding-right: 0;
      padding-block: clamp(3rem, 8vw, 5rem);
    }

    .hero__timeline {
      display: none;
    }

    .featured-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 360px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Measure actual header height and update hero
  const header = document.querySelector('.site-header') as HTMLElement | null;
  const hero = document.querySelector('.hero') as HTMLElement | null;
  if (header && hero) {
    const h = header.getBoundingClientRect().height;
    hero.style.setProperty('--_header-h', `${h}px`);
    hero.style.height = `calc(100svh - ${h}px)`;
  }
</script>
