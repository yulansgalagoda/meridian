---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ItemCard from '../../components/ItemCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getSiteData } from '../../lib/notion';

const { items, categories } = await getSiteData();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'The Meridian — Collection',
  url: 'https://meridian.yulan.me/collection',
  description: `${items.length} antiques and historical objects: maps, scientific instruments, rare books, photographs, and documents.`,
  isPartOf: { '@type': 'WebSite', name: 'The Meridian', url: 'https://meridian.yulan.me' },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: items.length,
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      url: `https://meridian.yulan.me/collection/${item.slug}`,
    })),
  },
};
---

<Base
  title="Collection"
  description={`Browse all ${items.length} antiques and historical objects in The Meridian archive — antique maps, scientific instruments, rare books, early photographs, and historical documents, filterable by era, origin, category, and condition.`}
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <div class="container" style="padding-bottom: clamp(4rem, 8vw, 7rem)">
      <header class="page-header">
        <p class="eyebrow eyebrow--accent">The Collection</p>
        <h1 class="page-header__title">All objects</h1>
        <p class="page-header__desc">
          {items.length} {items.length === 1 ? 'object' : 'objects'} in the archive.
        </p>
      </header>

      <FilterBar items={items} categories={categories} />

      <p class="filter-count" id="filter-count" aria-live="polite"></p>

      <div class="item-grid" id="item-grid">
        {items.map((item) => (
          <ItemCard item={item} />
        ))}
      </div>

      {items.length === 0 && (
        <p class="no-results">Nothing here yet.</p>
      )}
    </div>
  </main>

  <Footer itemCount={items.length} />
</Base>
