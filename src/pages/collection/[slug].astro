---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ItemCard from '../../components/ItemCard.astro';
import { getSiteData, fetchItemContent } from '../../lib/notion';

export async function getStaticPaths() {
  const { items } = await getSiteData();
  return items.map((item, idx) => ({
    params: { slug: item.slug },
    props: {
      item,
      prevItem: idx > 0 ? { slug: items[idx - 1].slug, name: items[idx - 1].name } : null,
      nextItem: idx < items.length - 1 ? { slug: items[idx + 1].slug, name: items[idx + 1].name } : null,
    },
  }));
}

const { item, prevItem, nextItem } = Astro.props;
const { items, narratives } = await getSiteData();
const bodyHtml = await fetchItemContent(item.id);

const allImages = [...(item.primaryImage ? [item.primaryImage] : []), ...item.galleryImages];

const dashless = (s: string) => s.replace(/-/g, '');
const itemNarratives = narratives.filter(
  (n) => n.publishStatus === 'Published' && item.narrativeIds.includes(dashless(n.id))
);

const related = items.filter((i) => i.id !== item.id && item.categorySlug && i.categorySlug === item.categorySlug).slice(0, 3);

const yearLabel = item.year !== null
  ? (item.year < 0 ? `${Math.abs(item.year)} BCE` : String(item.year))
  : null;

const wallRows = [
  { label: 'Date', value: item.year !== null ? (item.dateDetail ? `${yearLabel} · ${item.dateDetail}` : yearLabel) : item.dateDetail || null },
  { label: 'Maker', value: item.maker || null },
  { label: 'Origin', value: item.originCountry || null },
  { label: 'Materials', value: item.materials || null },
  { label: 'Dimensions', value: item.dimensions || null },
  { label: 'Condition', value: item.condition || null },
  { label: 'Field', value: item.categoryName || null },
].filter((f) => f.value !== null);

const verificationClass =
  item.verification === 'Verified' ? 'badge--verified'
  : item.verification === 'Research Ongoing' ? 'badge--research'
  : item.verification === 'Unverified' ? 'badge--unverified'
  : null;
const verificationMark = item.verification === 'Verified' ? '✓' : item.verification ? '◌' : '';

const bylineParts = [
  item.categoryName ? `From the ${item.categoryName} Shelf` : null,
  item.dateDetail || yearLabel,
].filter(Boolean);

const pageUrl = `https://meridian.yulan.me/collection/${item.slug}`;
const seoDescription = item.shortDescription || item.story || `${item.name} — an object in The Meridian archive.`;

const creativeWork: Record<string, unknown> = {
  '@context': 'https://schema.org', '@type': 'CreativeWork', name: item.name, url: pageUrl, description: seoDescription,
  ...(item.primaryImage && { image: `https://meridian.yulan.me${item.primaryImage}` }),
  ...(item.year !== null && { dateCreated: String(item.year) }),
  ...(item.maker && { creator: { '@type': 'Organization', name: item.maker } }),
  ...(item.materials && { material: item.materials }),
  ...(item.originCountry && { countryOfOrigin: { '@type': 'Country', name: item.originCountry } }),
  ...(item.tags.length && { keywords: item.tags.join(', ') }),
  isPartOf: { '@type': 'Collection', name: 'The Meridian Collection', url: 'https://meridian.yulan.me/collection' },
};
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Collection', item: 'https://meridian.yulan.me/collection' },
    ...(item.categoryName && item.categorySlug ? [{ '@type': 'ListItem', position: 2, name: item.categoryName, item: `https://meridian.yulan.me/categories/${item.categorySlug}` }] : []),
    { '@type': 'ListItem', position: item.categoryName ? 3 : 2, name: item.name, item: pageUrl },
  ],
};
---

<Base title={item.name} description={seoDescription} image={item.primaryImage ?? undefined} type="article" jsonLd={[creativeWork, breadcrumbs]}>
  <Header />

  <main class="item-page">
    <div class="container">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/collection">Collection</a>
        {item.categoryName && item.categorySlug && (<><span class="sep">/</span><a href={`/categories/${item.categorySlug}`}>{item.categoryName}</a></>)}
      </nav>

      <article>
        <div class="art-head">
          {item.categoryName && <p class="art-kicker">{item.categoryName}</p>}
          <h1>{item.name}</h1>
          {item.shortDescription && <p class="art-deck">{item.shortDescription}</p>}
          <p class="art-byline">
            <span>{bylineParts.join(' · ')}</span>
            {verificationClass && <span class={`badge ${verificationClass}`}>{verificationMark} {item.verification}</span>}
          </p>
        </div>

        <figure class="art-figure" id="lightbox-trigger">
          {item.primaryImage ? (
            <img src={item.primaryImage} alt={item.imageAltText || item.name} loading="eager" decoding="async" id="primary-img" />
          ) : (
            <div class="art-figure__placeholder">
              {yearLabel && <span class="py">{yearLabel}</span>}
              <span class="pl">No photograph</span>
            </div>
          )}
          {item.materials && item.primaryImage && <figcaption class="figcaption">{item.materials}</figcaption>}
        </figure>

        {allImages.length > 1 && (
          <div class="gallery-strip" id="gallery-strip">
            {allImages.map((src, i) => (
              <img src={src} alt={`${item.name} — view ${i + 1}`} class={`gallery-thumb${i === 0 ? ' is-active' : ''}`} loading="lazy" decoding="async" data-src={src} />
            ))}
          </div>
        )}

        {wallRows.length > 0 && (
          <aside class="factbox factbox--wide">
            <div class="factbox__head">The Wall Label</div>
            <dl>
              {wallRows.map((row) => (<div class="row"><dt>{row.label}</dt><dd>{row.value}</dd></div>))}
              {itemNarratives.length > 0 && (
                <div class="row"><dt>Narratives</dt><dd>{itemNarratives.map((n, i) => (<>{i ? ', ' : ''}<a href={`/narratives/${n.slug}`}>{n.name}</a></>))}</dd></div>
              )}
            </dl>
          </aside>
        )}
      </article>
    </div>

    <div class="container container--narrow">
      {bodyHtml && <article class="item-body" set:html={bodyHtml} />}

      {item.provenance && (
        <div class="provenance"><p class="provenance__k">Provenance</p><p>{item.provenance}</p></div>
      )}

      {item.tags.length > 0 && (
        <div class="tag-list">{item.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      )}
    </div>

    {related.length > 0 && (
      <div class="container">
        <div class="sec-head"><span>Also in {item.categoryName}</span></div>
        <div class="item-grid">{related.map((r) => <ItemCard item={r} />)}</div>
      </div>
    )}

    {(prevItem || nextItem) && (
      <div class="container container--narrow">
        <div class="item-pagination">
          <div class="item-pagination__inner">
            {prevItem ? (
              <a href={`/collection/${prevItem.slug}`} class="item-pagination__link">
                <span class="item-pagination__label">← Previous</span>
                <span class="item-pagination__name">{prevItem.name}</span>
              </a>
            ) : <div />}
            {nextItem ? (
              <a href={`/collection/${nextItem.slug}`} class="item-pagination__link item-pagination__link--next">
                <span class="item-pagination__label">Next →</span>
                <span class="item-pagination__name">{nextItem.name}</span>
              </a>
            ) : <div />}
          </div>
        </div>
      </div>
    )}

    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
      <button class="lightbox__close" id="lightbox-close" aria-label="Close">✕</button>
      <img class="lightbox__img" id="lightbox-img" src="" alt="" />
    </div>
  </main>

  <Footer />
</Base>

<script>
  const primaryImg = document.getElementById('primary-img') as HTMLImageElement | null;
  const strip = document.getElementById('gallery-strip');
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close');

  strip?.addEventListener('click', (e) => {
    const thumb = (e.target as Element).closest<HTMLElement>('.gallery-thumb');
    if (!thumb || !primaryImg) return;
    primaryImg.src = thumb.dataset.src!;
    strip.querySelectorAll('.gallery-thumb').forEach((t) => t.classList.remove('is-active'));
    thumb.classList.add('is-active');
  });

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src; lightboxImg.alt = alt;
    lightbox.classList.add('is-open'); document.body.style.overflow = 'hidden';
  }
  function closeLightbox() { lightbox.classList.remove('is-open'); document.body.style.overflow = ''; }

  document.getElementById('lightbox-trigger')?.addEventListener('click', () => { if (primaryImg) openLightbox(primaryImg.src, primaryImg.alt); });
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
