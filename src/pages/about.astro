---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSiteData } from '../lib/notion';

const { aboutHtml, items, categories } = await getSiteData();
---

<Base
  title="About"
  description="About The Meridian — a private archive of antiques and historical objects kept by Yulan Galagoda: what it collects, why, and how to get in touch about research, viewing, or objects."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: 'About The Meridian',
    url: 'https://meridian.yulan.me/about',
    mainEntity: {
      '@type': 'Person',
      name: 'Yulan Galagoda',
      url: 'https://yulan.me',
      email: 'mailto:yulangalagoda1@gmail.com',
      jobTitle: 'Curator',
      address: { '@type': 'PostalAddress', addressLocality: 'Plymouth', addressCountry: 'GB' },
    },
  }}
>
  <Header />

  <main>
    <div class="container">

      <!-- ── Page header ────────────────────────────────────────────────────── -->
      <header class="about-header">
        <p class="eyebrow eyebrow--accent">About</p>
        <h1 class="about-title">The Meridian</h1>
        <p class="about-subtitle">
          A personal archive of antiques and historical objects, kept by Yulan Galagoda.
        </p>
      </header>

      <!-- ── Two-column body ───────────────────────────────────────────────── -->
      <div class="about-grid">

        <!-- Left: Notion body -->
        <article class="about-body" set:html={aboutHtml} />

        <!-- Right: Profile + contact -->
        <aside class="about-sidebar">

          <div class="sidebar-profile">
            <div class="profile-badge" aria-hidden="true">YG</div>
            <a href="https://yulan.me" class="profile-name" target="_blank" rel="noopener">Yulan Galagoda</a>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label eyebrow eyebrow--muted">Contact</p>
            <a href="mailto:yulangalagoda1@gmail.com" class="sidebar-email">
              yulangalagoda1@gmail.com
            </a>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label eyebrow eyebrow--muted">Location</p>
            <p class="sidebar-val">Plymouth, United Kingdom</p>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label eyebrow eyebrow--muted">The archive</p>
            <p class="sidebar-val sidebar-val--large">{items.length} objects</p>
            <p class="sidebar-val">{categories.length} categories</p>
            <a href="/collection" class="sidebar-link">
              Browse the collection
              <svg viewBox="0 0 16 10" width="11" height="7" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M1 5h14M10 1l5 4-5 4"/>
              </svg>
            </a>
          </div>

        </aside>
      </div>

    </div>
  </main>

  <Footer itemCount={items.length} />
</Base>

<style>
  .about-header {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--rule);
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
    max-width: 720px;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.05;
    color: var(--ink);
    margin-top: var(--sp-4);
  }

  .about-subtitle {
    margin-top: var(--sp-5);
    font-size: var(--text-base);
    color: var(--ink-mute);
    line-height: 1.7;
    max-width: 52ch;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 0;
    padding-bottom: clamp(4rem, 8vw, 6rem);
    align-items: start;
  }

  .about-body {
    padding-right: clamp(2rem, 4vw, 3.5rem);
    border-right: 1px solid var(--rule);
  }

  .about-body :global(p) {
    max-width: 58ch;
    text-align: justify;
    hyphens: auto;
  }

  .about-sidebar {
    padding-left: clamp(2rem, 3.5vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-profile {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding-bottom: var(--sp-6);
    border-bottom: 1px solid var(--rule);
  }

  .profile-badge {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    background: var(--oxblood);
    color: var(--stone);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    user-select: none;
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
    text-decoration: none;
    transition: color var(--dur-base) var(--ease-io);
  }

  .profile-name:hover {
    color: var(--oxblood);
  }

  .sidebar-section {
    padding-top: var(--sp-6);
    padding-bottom: var(--sp-6);
    border-bottom: 1px solid var(--rule);
  }

  .sidebar-section:last-child {
    border-bottom: none;
  }

  .sidebar-label {
    margin-bottom: var(--sp-2);
  }

  .sidebar-email {
    font-size: var(--text-sm);
    color: var(--oxblood);
    text-decoration: none;
    word-break: break-all;
    line-height: 1.5;
    transition: color var(--dur-base) var(--ease-io);
  }

  .sidebar-email:hover {
    color: var(--oxblood-2);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sidebar-val {
    font-size: var(--text-sm);
    color: var(--ink-mute);
    line-height: 1.6;
  }

  .sidebar-val--large {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1;
    margin-bottom: var(--sp-1);
  }

  .sidebar-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--oxblood);
    text-decoration: none;
    transition: gap var(--dur-slow) var(--ease-out), color var(--dur-base) var(--ease-io);
  }

  .sidebar-link:hover {
    color: var(--oxblood-2);
    gap: calc(var(--sp-2) + 4px);
  }

  @media (max-width: 800px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-body {
      border-right: none;
      border-bottom: 1px solid var(--rule);
      padding-right: 0;
      padding-bottom: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: clamp(2.5rem, 5vw, 4rem);
    }

    .about-sidebar {
      padding-left: 0;
    }

    .about-header {
      max-width: none;
    }
  }
</style>
