---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description = 'A curated archive of antiques and historical objects.',
  image,
  canonical,
  type = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

const siteName = 'The Meridian';
const siteUrl = 'https://meridian.yulan.me';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const url = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

// Absolute image URL for social cards
const ogImage = image
  ? (image.startsWith('http') ? image : new URL(image, siteUrl).href)
  : new URL('/og-default.png', siteUrl).href;

const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="Yulan Galagoda" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_GB" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data -->
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <slot name="head" />

    <!-- WebMCP: register site context for browser-based AI agents -->
    <script>
      if (typeof navigator !== 'undefined' && 'modelContext' in navigator) {
        (navigator as any).modelContext.provideContext({
          name: 'The Meridian',
          description: 'A private archive of antiques and historical objects spanning 1590 to the present, curated by Yulan Galagoda.',
          tools: [
            {
              name: 'get_overview',
              description: 'Returns a summary of The Meridian archive including its purpose, curator, and collection scope.',
              run: () => ({
                name: 'The Meridian',
                curator: 'Yulan Galagoda',
                description: 'A private archive of antiques and historical objects spanning 1590 to the present.',
                url: 'https://meridian.yulan.me',
                collection: 'https://meridian.yulan.me/collection',
                narratives: 'https://meridian.yulan.me/narratives',
                categories: 'https://meridian.yulan.me/categories',
                about: 'https://meridian.yulan.me/about',
                llms: 'https://meridian.yulan.me/llms.txt',
              }),
            },
          ],
        });
      }
    </script>
  </head>
  <body>
    <slot />

    <!-- Scroll reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal, .obj-card').forEach((el) => observer.observe(el));
    </script>

    <!-- Header scroll shadow -->
    <script>
      const header = document.querySelector('.site-header');
      if (header) {
        const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 8);
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>

    <!-- Back to top -->
    <button class="back-to-top" id="back-to-top" aria-label="Back to top">
      <svg viewBox="0 0 12 7" width="12" height="7" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M1 6L6 1l5 5"/>
      </svg>
    </button>

    <script>
      const btn = document.getElementById('back-to-top');
      if (btn) {
        window.addEventListener('scroll', () => {
          btn.classList.toggle('is-visible', window.scrollY > 400);
        }, { passive: true });
        btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }
    </script>
  </body>
</html>
