---
import type { Item, Category } from '../lib/types';

interface Props {
  items: Item[];
  categories: Category[];
}

const { items, categories } = Astro.props;

function unique(vals: string[]): string[] {
  return [...new Set(vals.filter(Boolean))].sort();
}

const eras = unique(items.map((i) => i.era));
const countries = unique(items.map((i) => i.originCountry));
const conditions = unique(items.map((i) => i.condition));
const allTags = unique(items.flatMap((i) => i.tags));
const catOptions = categories
  .filter((c) => items.some((i) => i.categorySlug === c.slug))
  .sort((a, b) => a.displayOrder - b.displayOrder);

const groups = [
  { key: 'era', label: 'Era', options: eras },
  { key: 'category', label: 'Category', options: catOptions.map((c) => c.name) },
  { key: 'origin', label: 'Origin', options: countries },
  { key: 'tag', label: 'Tags', options: allTags },
  { key: 'condition', label: 'Condition', options: conditions },
].filter((g) => g.options.length > 0);
---

<div class="filter-bar" id="filter-bar" aria-label="Filter collection">
  <div class="filter-groups">
    {groups.map((group) => (
      <div class="filter-group" data-group-key={group.key}>
        <span class="filter-group__label">{group.label}</span>
        <div class="filter-group__pills">
          {group.options.map((opt) => (
            <button
              class="filter-btn"
              data-filter-key={group.key}
              data-filter-val={opt}
              type="button"
              aria-pressed="false"
            >
              {opt}
            </button>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  const bar = document.getElementById('filter-bar');
  if (!bar) throw new Error('FilterBar not found');

  const countEl = document.getElementById('filter-count');
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('.item-card[data-filter]')
  );

  // Pre-parse card data once
  const cardData = cards.map((c) =>
    JSON.parse(c.dataset.filter ?? '{}') as Record<string, string | string[]>
  );

  // Active filters: key → Set of values (OR within group, AND across groups)
  const active = new Map<string, Set<string>>();

  function matchesFilters(
    data: Record<string, string | string[]>,
    filters: Map<string, Set<string>>
  ): boolean {
    return [...filters.entries()].every(([key, vals]) => {
      const v = data[key];
      if (Array.isArray(v)) return [...vals].some((fv) => v.includes(fv));
      return vals.has(String(v ?? ''));
    });
  }

  // How many items would be visible if we hypothetically added (key=val)?
  function countWithOption(key: string, val: string): number {
    const effective = new Map<string, Set<string>>();
    active.forEach((vals, k) => effective.set(k, new Set(vals)));
    if (!effective.has(key)) effective.set(key, new Set());
    effective.get(key)!.add(val);
    return cardData.filter((data) => matchesFilters(data, effective)).length;
  }

  function toggle(key: string, val: string) {
    if (!active.has(key)) active.set(key, new Set());
    const set = active.get(key)!;
    if (set.has(val)) set.delete(val);
    else set.add(val);
    if (set.size === 0) active.delete(key);
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach((card, i) => {
      const passes = active.size === 0 || matchesFilters(cardData[i], active);
      card.hidden = !passes;
      if (passes) {
        // Force-reveal items that match — they may not have been scrolled into
        // view yet so the IntersectionObserver hasn't added is-visible
        card.classList.add('is-visible');
        visible++;
      }
    });
    if (countEl) {
      countEl.textContent =
        active.size === 0
          ? ''
          : `${visible} ${visible === 1 ? 'object' : 'objects'}`;
    }
  }

  function updateCascade() {
    bar!.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
      const key = btn.dataset.filterKey!;
      const val = btn.dataset.filterVal!;
      const isActive = active.get(key)?.has(val) ?? false;
      // Always show active buttons so the user can deselect them
      if (isActive) {
        btn.hidden = false;
        return;
      }
      btn.hidden = countWithOption(key, val) === 0;
    });

    // Hide groups where every button is hidden
    bar!.querySelectorAll<HTMLElement>('.filter-group').forEach((group) => {
      const btns = [...group.querySelectorAll<HTMLButtonElement>('.filter-btn')];
      group.hidden = btns.every((b) => b.hidden);
    });
  }

  bar.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.filter-btn');
    if (!btn) return;
    const key = btn.dataset.filterKey!;
    const val = btn.dataset.filterVal!;
    toggle(key, val);
    const isActive = active.get(key)?.has(val) ?? false;
    btn.classList.toggle('is-active', isActive);
    btn.setAttribute('aria-pressed', String(isActive));
    applyFilters();
    updateCascade();
  });
</script>
