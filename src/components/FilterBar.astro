---
import type { Item, Category } from '../lib/types';

interface Props {
  items: Item[];
  categories: Category[];
}

const { items, categories } = Astro.props;

function slug(s: string): string {
  return (s ?? '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

function unique(vals: string[]): string[] {
  return [...new Set(vals.filter(Boolean))].sort();
}

const eras = unique(items.map((i) => i.era));
const countries = unique(items.map((i) => i.originCountry));
const conditions = unique(items.map((i) => i.condition));
const allTags = unique(items.flatMap((i) => i.tags));
const catOptions = categories
  .filter((c) => items.some((i) => i.categorySlug === c.slug))
  .sort((a, b) => a.displayOrder - b.displayOrder);

const groups = [
  { key: 'era',       label: 'Era',       options: eras.map((v) => ({ label: v, val: slug(v) })) },
  { key: 'category',  label: 'Category',  options: catOptions.map((c) => ({ label: c.name, val: slug(c.name) })) },
  { key: 'origin',    label: 'Origin',    options: countries.map((v) => ({ label: v, val: slug(v) })) },
  { key: 'tag',       label: 'Tags',      options: allTags.map((v) => ({ label: v, val: slug(v) })) },
  { key: 'condition', label: 'Condition', options: conditions.map((v) => ({ label: v, val: slug(v) })) },
].filter((g) => g.options.length > 0);
---

<div class="filter-bar" id="filter-bar" aria-label="Filter collection">

  <!-- Mobile toggle — hidden on desktop -->
  <button
    class="filter-toggle"
    id="filter-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="filter-groups"
  >
    <span class="filter-toggle__left">
      <svg viewBox="0 0 16 12" width="14" height="12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <path d="M1 1h14M4 6h8M7 11h2"/>
      </svg>
      <span>Filters</span>
      <span class="filter-toggle__badge" id="filter-toggle-badge"></span>
    </span>
    <svg class="filter-toggle__chevron" viewBox="0 0 12 7" width="11" height="7" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <path d="M1 1l5 5 5-5"/>
    </svg>
  </button>

  <!-- Filter groups — always visible on desktop, toggled on mobile -->
  <div class="filter-groups" id="filter-groups">
    {groups.map((group) => (
      <div class="filter-group" data-group-key={group.key}>
        <span class="filter-group__label">{group.label}</span>
        <div class="filter-group__pills">
          {group.options.map((opt) => (
            <button
              class="filter-btn"
              data-filter-key={group.key}
              data-filter-val={opt.val}
              type="button"
              aria-pressed="false"
            >
              {opt.label}
            </button>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<!-- Active filter chips — rendered by JS, always visible -->
<div class="active-filters" id="active-filters" aria-live="polite"></div>

<style>
  /* Mobile toggle — hidden on desktop */
  .filter-toggle {
    display: none;
  }

  @media (max-width: 640px) {
    /* Toggle button */
    .filter-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: var(--sp-3) var(--sp-4);
      background: transparent;
      border: 1px solid var(--stone-4);
      color: var(--ink);
      font-family: var(--font-body);
      font-size: var(--text-sm);
      font-weight: 500;
      letter-spacing: 0.01em;
      cursor: pointer;
      transition: border-color 0.25s ease, background 0.25s ease;
      margin-bottom: 0;
    }

    .filter-toggle:hover {
      border-color: var(--stone-4);
      background: var(--stone-2);
    }

    .filter-toggle[aria-expanded="true"] {
      border-color: var(--ink-faint);
      background: var(--stone-2);
    }

    .filter-toggle__left {
      display: flex;
      align-items: center;
      gap: var(--sp-3);
    }

    .filter-toggle__badge {
      display: none;
      background: var(--oxblood);
      color: var(--stone);
      font-size: 0.65rem;
      font-weight: 600;
      line-height: 1;
      padding: 0.2em 0.5em;
      border-radius: 99px;
      min-width: 1.3em;
      text-align: center;
    }

    .filter-toggle__badge.has-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .filter-toggle__chevron {
      flex-shrink: 0;
      color: var(--ink-faint);
      transition: transform 0.3s ease;
    }

    .filter-toggle[aria-expanded="true"] .filter-toggle__chevron {
      transform: rotate(180deg);
    }

    /* Filter groups hidden by default on mobile */
    .filter-groups {
      display: none;
      padding: var(--sp-5) 0 var(--sp-2);
      border-top: 1px solid var(--stone-3);
      margin-top: var(--sp-1);
    }

    .filter-groups.is-open {
      display: block;
    }
  }
</style>

<script>
  (function () {
    const bar = document.getElementById('filter-bar');
    if (!bar) return;

    const countEl = document.getElementById('filter-count');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.item-card'));

    // Active filters: key → Set<slugified value>
    const active: Record<string, Set<string>> = {
      era: new Set(),
      category: new Set(),
      origin: new Set(),
      tag: new Set(),
      condition: new Set(),
    };

    // ── Mobile toggle ──────────────────────────────────────────────────────────
    const filterToggle = document.getElementById('filter-toggle') as HTMLButtonElement | null;
    const filterGroups = document.getElementById('filter-groups');
    const filterToggleBadge = document.getElementById('filter-toggle-badge');

    filterToggle?.addEventListener('click', () => {
      const isOpen = filterGroups?.classList.toggle('is-open') ?? false;
      filterToggle.setAttribute('aria-expanded', String(isOpen));
    });

    function updateToggleBadge() {
      if (!filterToggleBadge) return;
      const total = Object.values(active).reduce((sum, s) => sum + s.size, 0);
      filterToggleBadge.textContent = total > 0 ? String(total) : '';
      filterToggleBadge.classList.toggle('has-count', total > 0);
    }

    // ── Filter logic ───────────────────────────────────────────────────────────
    function countWith(filters: Record<string, Set<string>>): number {
      let n = 0;
      cards.forEach((card) => {
        for (const [key, set] of Object.entries(filters)) {
          if (!set.size) continue;
          const cardVals = (card.dataset[key] ?? '').split('|').filter(Boolean);
          if (!cardVals.some((v) => set.has(v))) return;
        }
        n++;
      });
      return n;
    }

    function updateCascade() {
      bar!.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
        const key = btn.dataset.filterKey!;
        const val = btn.dataset.filterVal!;
        if (active[key]?.has(val)) { btn.style.display = ''; return; }
        const hypo: Record<string, Set<string>> = {};
        for (const [k, s] of Object.entries(active)) hypo[k] = new Set(s);
        (hypo[key] ??= new Set()).add(val);
        btn.style.display = countWith(hypo) === 0 ? 'none' : '';
      });

      bar!.querySelectorAll<HTMLElement>('.filter-group').forEach((group) => {
        const btns = [...group.querySelectorAll<HTMLButtonElement>('.filter-btn')];
        group.style.display = btns.every((b) => b.style.display === 'none') ? 'none' : '';
      });
    }

    function applyFilters() {
      const hasActive = Object.values(active).some((s) => s.size > 0);
      let visible = 0;

      cards.forEach((card) => {
        let passes = true;
        for (const [key, set] of Object.entries(active)) {
          if (!set.size) continue;
          const cardVals = (card.dataset[key] ?? '').split('|').filter(Boolean);
          if (!cardVals.some((v) => set.has(v))) { passes = false; break; }
        }
        card.style.display = passes ? '' : 'none';
        if (passes) { card.classList.add('is-visible'); visible++; }
      });

      if (countEl) {
        countEl.textContent = hasActive
          ? `${visible} ${visible === 1 ? 'object' : 'objects'}`
          : '';
      }

      updateCascade();
      updateToggleBadge();
    }

    const activeFiltersEl = document.getElementById('active-filters');

    function renderActiveChips() {
      if (!activeFiltersEl) return;
      const chips: string[] = [];
      bar!.querySelectorAll<HTMLButtonElement>('.filter-btn.is-active').forEach((btn) => {
        const key = btn.dataset.filterKey!;
        const val = btn.dataset.filterVal!;
        const label = btn.textContent?.trim() ?? val;
        chips.push(`<button class="active-chip" data-clear-key="${key}" data-clear-val="${val}" type="button">${label} <span aria-hidden="true">×</span></button>`);
      });
      activeFiltersEl.innerHTML = chips.length
        ? `<div class="active-chips">${chips.join('')}<button class="active-chips__clear" id="clear-all-filters" type="button">Clear all</button></div>`
        : '';
      updateToggleBadge();
    }

    activeFiltersEl?.addEventListener('click', (e) => {
      const chip = (e.target as Element).closest<HTMLButtonElement>('.active-chip');
      if (chip) {
        const key = chip.dataset.clearKey!;
        const val = chip.dataset.clearVal!;
        active[key].delete(val);
        const filterBtn = bar!.querySelector<HTMLButtonElement>(`[data-filter-key="${key}"][data-filter-val="${val}"]`);
        if (filterBtn) { filterBtn.classList.remove('is-active'); filterBtn.setAttribute('aria-pressed', 'false'); }
        applyFilters();
        renderActiveChips();
        return;
      }
      if ((e.target as Element).id === 'clear-all-filters') {
        Object.keys(active).forEach((k) => active[k].clear());
        bar!.querySelectorAll<HTMLButtonElement>('.filter-btn.is-active').forEach((b) => {
          b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false');
        });
        applyFilters();
        renderActiveChips();
      }
    });

    bar.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest<HTMLButtonElement>('.filter-btn');
      if (!btn) return;
      const key = btn.dataset.filterKey!;
      const val = btn.dataset.filterVal!;
      if (active[key].has(val)) active[key].delete(val);
      else active[key].add(val);
      const isActive = active[key].has(val);
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', String(isActive));
      applyFilters();
      renderActiveChips();
    });
  })();
</script>
