---
import '../styles/global.css';
import { getSiteData } from '../lib/notion';

const { narratives } = await getSiteData();
const hasNarratives = narratives.some((n) => n.publishStatus === 'Published');

const nav = [
  { href: '/collection', label: 'Collection' },
  { href: '/categories', label: 'Categories' },
  ...(hasNarratives ? [{ href: '/narratives', label: 'Narratives' }] : []),
  { href: '/seeking', label: 'Seeking' },
  { href: '/about', label: 'About' },
];

const pathname = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<header class="site-header">
  <div class="container">
    <div class="topstrip">
      <span>A Record, Not a Shop</span>
      <span class="topstrip__center">Ceylon &middot; Britain &middot; the Wider World</span>
      <button class="topstrip__toggle" id="edition-toggle" type="button" aria-label="Switch edition">
        <span id="edition-label">Evening Edition</span>
      </button>
    </div>

    <div class="masthead">
      <div class="masthead__flourish" aria-hidden="true">✦</div>
      <a href="/" class="masthead__title">The Meridian</a>
      <div class="rule-double" style="margin-top: 12px"></div>
      <p class="masthead__tagline">A Private Archive of Antiques &amp; Historical Objects</p>
    </div>

    <nav class="sectionbar" aria-label="Primary navigation">
      {nav.map(({ href, label }) => (
        <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var btn = document.getElementById('edition-toggle');
    var label = document.getElementById('edition-label');
    function sync() {
      var evening = root.getAttribute('data-theme') === 'evening';
      if (label) label.textContent = evening ? 'Day Edition' : 'Evening Edition';
    }
    sync();
    if (btn) {
      btn.addEventListener('click', function () {
        var evening = root.getAttribute('data-theme') === 'evening';
        if (evening) { root.removeAttribute('data-theme'); try { localStorage.setItem('meridian-edition', 'day'); } catch (e) {} }
        else { root.setAttribute('data-theme', 'evening'); try { localStorage.setItem('meridian-edition', 'evening'); } catch (e) {} }
        sync();
      });
    }
  })();
</script>
