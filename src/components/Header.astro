---
import '../styles/global.css';
import { getSiteData } from '../lib/notion';

const { narratives } = await getSiteData();
const hasNarratives = narratives.some((n) => n.publishStatus === 'Published');

const nav = [
  { href: '/collection', label: 'Collection' },
  { href: '/categories', label: 'Categories' },
  ...(hasNarratives ? [{ href: '/narratives', label: 'Narratives' }] : []),
  { href: '/seeking', label: 'Seeking' },
  { href: '/about', label: 'About' },
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="container">
    <div class="site-header__inner">
      <a href="/" class="site-logo"><span class="site-logo__mark">✦</span> The Meridian</a>
      <nav aria-label="Primary navigation">
        <ul class="site-nav">
          {nav.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={pathname.startsWith(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>
