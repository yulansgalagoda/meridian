---
import { getSiteData } from '../lib/notion';

interface Props {
  itemCount?: number;
}
const { itemCount } = Astro.props;
const year = new Date().getFullYear();

const { narratives } = await getSiteData();
const hasNarratives = narratives.some((n) => n.publishStatus === 'Published');

const explore = [
  { href: '/collection', label: 'Collection' },
  { href: '/categories', label: 'Categories' },
  ...(hasNarratives ? [{ href: '/narratives', label: 'Narratives' }] : []),
  { href: '/about', label: 'About' },
];

const archive = [
  { href: '/collecting-policy', label: 'Collecting Policy' },
  { href: '/verification-and-provenance', label: 'Verification & Provenance' },
  { href: '/seeking', label: 'Seeking' },
  { href: '/access-citation-image-use', label: 'Access, Citation & Image Use' },
  { href: '/annual-review', label: 'Annual Review' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div>
        <a href="/" class="site-footer__name"><span>✦</span> The Meridian</a>
        <p class="site-footer__pali">
          Vayadhammā saṅkhārā — all conditioned things are subject to decay.
          <small>Mahāparinibbāna Sutta · Dīgha Nikāya 16</small>
        </p>
      </div>
      <nav class="site-footer__col" aria-label="Explore">
        <h4>Explore</h4>
        <ul>
          {explore.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </nav>
      <nav class="site-footer__col" aria-label="The Archive">
        <h4>The Archive</h4>
        <ul>
          {archive.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
    <div class="site-footer__base">
      <span>{itemCount !== undefined && `${itemCount} ${itemCount === 1 ? 'object' : 'objects'} · `}YG · {year}</span>
      <span>A record, not a shop</span>
      <p class="site-footer__credit">
        Designed by Yulan Galagoda · Built in collaboration with AI (Perplexity, Claude) on Astro and Notion · Hosted on Cloudflare Pages
      </p>
    </div>
  </div>
</footer>
