---
import type { Item } from '../lib/types';
import { TIMELINE_SEGMENTS } from '../lib/types';

interface Props {
  items: Item[];
}

const { items } = Astro.props;

const currentYear = new Date().getFullYear();

type Segment = {
  label: string;
  from: number;
  to: number;
  items: Array<{ slug: string; name: string; year: number }>;
};

const segments: Segment[] = TIMELINE_SEGMENTS.reduce<Segment[]>((acc, seg) => {
  const segItems = items
    .filter((item) => {
      if (item.year === null) return false;
      const lo = seg.from === -Infinity ? -Infinity : seg.from;
      const hi = seg.to === Infinity ? Infinity : seg.to;
      return item.year >= lo && item.year <= hi;
    })
    .map((item) => ({ slug: item.slug, name: item.name, year: item.year as number }))
    .sort((a, b) => a.year - b.year);

  if (segItems.length > 0) {
    acc.push({ label: seg.label, from: seg.from, to: seg.to, items: segItems });
  }
  return acc;
}, []);

// Start on the most populated segment
const defaultIdx = segments.reduce((best, seg, idx) =>
  seg.items.length > segments[best].items.length ? idx : best, 0);

// SVG dimensions
const VB_W = 300;
const VB_H = 400;
const LINE_X = 148;
const DOT_R = 7;
const BRANCH_LEN = 62;
const PAD_Y = 40;

function dotY(year: number, lo: number, hi: number): number {
  if (hi === lo) return VB_H / 2;
  return PAD_Y + ((year - lo) / (hi - lo)) * (VB_H - PAD_Y * 2);
}

function buildSegmentSVG(seg: Segment): string {
  const lo = seg.from === -Infinity ? seg.items[0].year : seg.from;
  const hi = seg.to === Infinity ? currentYear : seg.to;

  const loLabel = lo < 0 ? `${Math.abs(lo)} BCE` : String(lo);
  const hiLabel = hi === currentYear ? String(currentYear) : String(hi);

  // Large watermark year — faint Cormorant behind the spine
  const wmText = lo === -Infinity ? String(seg.items[0].year) : String(lo);
  const watermark = `<text x="${VB_W / 2}" y="${VB_H / 2 + 28}" font-family="Cormorant Garamond, Georgia, serif" font-style="italic" font-weight="300" font-size="108" fill="var(--stone-3)" text-anchor="middle" dominant-baseline="middle" pointer-events="none" aria-hidden="true">${wmText}</text>`;

  let dots = '';
  seg.items.forEach((item, i) => {
    const y = dotY(item.year, lo, hi);
    const side = i % 2 === 0 ? 1 : -1;
    const bx = LINE_X + side * BRANCH_LEN;
    const anchor = side === 1 ? 'start' : 'end';
    const labelX = bx + side * 10;
    const yearDisp = item.year < 0 ? `${Math.abs(item.year)} BCE` : String(item.year);

    dots += `
      <g class="tl-dot" data-slug="${item.slug}" data-name="${item.name.replace(/"/g, '&quot;')}" data-year="${item.year}" style="cursor:pointer">
        <line x1="${LINE_X}" y1="${y}" x2="${bx}" y2="${y}" stroke="var(--stone-4)" stroke-width="1" stroke-dasharray="3 2"/>
        <circle cx="${bx}" cy="${y}" r="${DOT_R}" fill="var(--stone)" stroke="var(--oxblood)" stroke-width="2" class="tl-dot__circle"/>
        <text x="${labelX}" y="${y + 1}" font-size="12" font-weight="500" fill="var(--ink-mute)" dominant-baseline="middle" text-anchor="${anchor}" font-family="Inter Tight, sans-serif" class="tl-dot__year">${yearDisp}</text>
      </g>`;
  });

  return `
    ${watermark}
    <text x="${LINE_X}" y="${PAD_Y - 22}" font-size="10" font-weight="500" fill="var(--ink-faint)" text-anchor="middle" letter-spacing="2" font-family="Inter Tight, sans-serif">${loLabel}</text>
    <line x1="${LINE_X}" y1="${PAD_Y}" x2="${LINE_X}" y2="${VB_H - PAD_Y}" stroke="var(--ink-faint)" stroke-width="1.5"/>
    <circle cx="${LINE_X}" cy="${PAD_Y}" r="3" fill="var(--ink-faint)"/>
    <circle cx="${LINE_X}" cy="${VB_H - PAD_Y}" r="3" fill="var(--ink-faint)"/>
    <text x="${LINE_X}" y="${VB_H - PAD_Y + 22}" font-size="10" font-weight="500" fill="var(--ink-faint)" text-anchor="middle" letter-spacing="2" font-family="Inter Tight, sans-serif">${hiLabel}</text>
    ${dots}
  `;
}
---

{segments.length > 0 && (
  <div class="timeline" id="timeline" data-default={defaultIdx} aria-label="Collection timeline" role="region">

    <!-- Segment label row -->
    <div class="timeline__header">
      <span class="tl-seg-label" id="tl-seg-label">{segments[defaultIdx].label}</span>
      <span class="tl-count" id="tl-seg-count">
        {segments[defaultIdx].items.length} {segments[defaultIdx].items.length === 1 ? 'object' : 'objects'}
      </span>
    </div>

    <!-- SVG stage -->
    <div class="timeline__stage" id="tl-stage">
      {segments.map((seg, i) => (
        <svg
          class={`timeline__svg${i === defaultIdx ? ' is-active' : ' enter-from-below'}`}
          data-index={i}
          data-label={seg.label}
          data-count={seg.items.length}
          viewBox={`0 0 ${VB_W} ${VB_H}`}
          preserveAspectRatio="xMidYMid meet"
          aria-hidden="true"
          set:html={buildSegmentSVG(seg)}
        />
      ))}

      <!-- Tooltip -->
      <div class="tl-tooltip" id="tl-tooltip" role="tooltip">
        <span class="tl-tooltip__name" id="tl-tooltip-name"></span>
        <span class="tl-tooltip__year" id="tl-tooltip-year"></span>
      </div>
    </div>

    <!-- Navigation -->
    {segments.length > 1 && (
      <div class="timeline__nav">
        <button class="tl-arrow" id="tl-prev" aria-label="Earlier period" title="Earlier era">
          <svg viewBox="0 0 12 7" width="12" height="7" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M1 6L6 1l5 5"/>
          </svg>
        </button>
        <div class="tl-nav-center">
          <p class="tl-nav-hint">Navigate eras</p>
          <span class="tl-nav-dots" id="tl-nav-dots">
            {segments.map((seg, i) => (
              <span class={`tl-nav-dot${i === defaultIdx ? ' is-active' : ''}`} data-goto={i} title={seg.label} />
            ))}
          </span>
        </div>
        <button class="tl-arrow" id="tl-next" aria-label="Later period" title="Later era">
          <svg viewBox="0 0 12 7" width="12" height="7" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M1 1l5 5 5-5"/>
          </svg>
        </button>
      </div>
    )}
  </div>
)}

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    height: 100%;
    user-select: none;
  }

  .timeline__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--stone-4);
    margin-bottom: var(--sp-4);
    flex-shrink: 0;
  }

  .tl-seg-label {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--oxblood-light);
    transition: opacity 0.4s var(--ease-io);
  }

  .tl-count {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  /* Stage clips the sliding SVGs */
  .timeline__stage {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .timeline__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* default hidden state — below */
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 0.55s var(--ease-out),
      transform 0.55s var(--ease-out);
  }

  .timeline__svg.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  /* Positioned above, ready to slide down into view (going prev) */
  .timeline__svg.enter-from-above {
    transform: translateY(-32px);
    opacity: 0;
  }

  /* Exiting upward (going next) */
  .timeline__svg.exit-up {
    opacity: 0;
    transform: translateY(-32px);
    pointer-events: none;
  }

  /* Exiting downward (going prev) */
  .timeline__svg.exit-down {
    opacity: 0;
    transform: translateY(32px);
    pointer-events: none;
  }

  /* Dots */
  .tl-dot__circle {
    transition:
      r 0.4s var(--ease-out),
      fill 0.35s var(--ease-io);
  }

  .tl-dot:hover .tl-dot__circle {
    r: 10;
    fill: var(--oxblood-faint);
  }

  .tl-dot__year {
    transition: fill 0.3s var(--ease-io), font-size 0.3s var(--ease-io);
  }

  .tl-dot:hover .tl-dot__year {
    fill: var(--ink-soft);
    font-size: 13px;
  }

  /* Tooltip */
  .tl-tooltip {
    position: absolute;
    background: var(--ink);
    color: var(--stone);
    padding: 0.5rem 0.85rem;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    transition:
      opacity 0.3s var(--ease-io),
      transform 0.3s var(--ease-io);
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    max-width: 15rem;
  }

  .tl-tooltip.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .tl-tooltip__name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--stone);
  }

  .tl-tooltip__year {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* Nav */
  .timeline__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--sp-5);
    border-top: 1px solid var(--stone-4);
    margin-top: var(--sp-4);
    flex-shrink: 0;
    gap: var(--sp-3);
  }

  .tl-nav-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    flex: 1;
  }

  .tl-nav-hint {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out);
  }

  .tl-nav-hint.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tl-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: rgba(237, 232, 222, 0.06);
    border: 1px solid var(--stone-4);
    color: var(--ink-mute);
    cursor: pointer;
    transition:
      background 0.4s var(--ease-io),
      border-color 0.4s var(--ease-io),
      color 0.4s var(--ease-io),
      transform 0.3s var(--ease-out);
  }

  .tl-arrow:hover {
    background: rgba(237, 232, 222, 0.12);
    border-color: var(--oxblood-light);
    color: var(--oxblood-light);
  }

  .tl-arrow:disabled {
    opacity: 0.2;
    cursor: default;
    pointer-events: none;
  }

  @keyframes tl-pulse {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.15); }
    70%  { transform: scale(0.95); }
    100% { transform: scale(1); }
  }

  .tl-arrow.pulse {
    animation: tl-pulse 0.55s var(--ease-out) forwards;
  }

  .tl-nav-dots {
    display: flex;
    gap: var(--sp-3);
    align-items: center;
  }

  .tl-nav-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--stone-4);
    cursor: pointer;
    transition:
      background 0.4s var(--ease-io),
      transform 0.4s var(--ease-io);
  }

  .tl-nav-dot:hover {
    background: var(--oxblood-light);
    transform: scale(1.3);
  }

  .tl-nav-dot.is-active {
    background: var(--oxblood-light);
    transform: scale(1.5);
  }
</style>

<script>
  const stage = document.getElementById('tl-stage');
  if (!stage) throw new Error('Timeline stage not found');

  const svgs = Array.from(stage.querySelectorAll<SVGElement>('.timeline__svg'));
  const tooltip = document.getElementById('tl-tooltip')!;
  const tooltipName = document.getElementById('tl-tooltip-name')!;
  const tooltipYear = document.getElementById('tl-tooltip-year')!;
  const segLabel = document.getElementById('tl-seg-label')!;
  const segCount = document.getElementById('tl-seg-count')!;
  const prevBtn = document.getElementById('tl-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('tl-next') as HTMLButtonElement | null;
  const navDots = Array.from(document.querySelectorAll<HTMLElement>('.tl-nav-dot'));

  const defaultIdx = Number(document.getElementById('timeline')?.dataset.default ?? 0);
  let current = defaultIdx;
  let animating = false;

  function goTo(index: number, direction: 'next' | 'prev') {
    if (index < 0 || index >= svgs.length || animating) return;
    animating = true;

    const outgoing = svgs[current];
    const incoming = svgs[index];

    // Position incoming off-screen in the correct direction
    incoming.classList.remove('is-active', 'enter-from-above', 'enter-from-below', 'exit-up', 'exit-down');
    incoming.classList.add(direction === 'next' ? 'enter-from-below' : 'enter-from-above');

    // Force reflow so the initial transform is painted before transition
    incoming.getBoundingClientRect();

    // Slide outgoing out
    outgoing.classList.remove('is-active');
    outgoing.classList.add(direction === 'next' ? 'exit-up' : 'exit-down');

    // Slide incoming in
    incoming.classList.remove('enter-from-above', 'enter-from-below');
    incoming.classList.add('is-active');

    // Update labels
    current = index;
    segLabel.textContent = svgs[current].dataset.label ?? '';
    const count = Number(svgs[current].dataset.count ?? 0);
    segCount.textContent = `${count} ${count === 1 ? 'object' : 'objects'}`;

    // Update nav dots
    navDots.forEach((d, i) => d.classList.toggle('is-active', i === current));

    // Update buttons
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current === svgs.length - 1;

    setTimeout(() => {
      outgoing.classList.remove('exit-up', 'exit-down');
      animating = false;
    }, 600);
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1, 'prev'));
  nextBtn?.addEventListener('click', () => goTo(current + 1, 'next'));

  // Nav dot clicks
  navDots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i, i > current ? 'next' : 'prev'));
  });

  // Mousewheel — captured only when hovering the timeline
  const timeline = document.getElementById('timeline');
  let wheelCooldown = false;
  timeline?.addEventListener('wheel', (e: WheelEvent) => {
    e.preventDefault();
    if (wheelCooldown || animating) return;
    wheelCooldown = true;
    goTo(e.deltaY > 0 ? current + 1 : current - 1, e.deltaY > 0 ? 'next' : 'prev');
    setTimeout(() => { wheelCooldown = false; }, 700);
  }, { passive: false });

  // Tooltip
  stage.addEventListener('mouseover', (e) => {
    const dot = (e.target as Element).closest<Element>('.tl-dot');
    if (!dot) return;
    const name = dot.getAttribute('data-name') ?? '';
    const year = dot.getAttribute('data-year') ?? '';
    tooltipName.textContent = name;
    tooltipYear.textContent = year;

    const circle = dot.querySelector('circle');
    if (!circle) return;
    const stageRect = stage.getBoundingClientRect();
    const cr = circle.getBoundingClientRect();
    tooltip.style.top = `${cr.top - stageRect.top - 72}px`;
    tooltip.style.left = `${Math.max(4, cr.left - stageRect.left - 60)}px`;
    tooltip.classList.add('is-visible');
  });

  stage.addEventListener('mouseout', (e) => {
    if ((e.target as Element).closest('.tl-dot')) tooltip.classList.remove('is-visible');
  });

  stage.addEventListener('click', (e) => {
    const dot = (e.target as Element).closest<Element>('.tl-dot');
    if (dot?.getAttribute('data-slug')) {
      window.location.href = `/collection/${dot.getAttribute('data-slug')}`;
    }
  });

  // Init state based on defaultIdx
  if (prevBtn) prevBtn.disabled = current === 0;
  if (nextBtn) nextBtn.disabled = current === svgs.length - 1;

  // Reveal "Navigate eras" hint + pulse next arrow after a brief delay
  const hint = document.querySelector<HTMLElement>('.tl-nav-hint');
  if (hint && nextBtn && !nextBtn.disabled) {
    setTimeout(() => {
      hint.classList.add('is-visible');
      nextBtn.classList.add('pulse');
      nextBtn.addEventListener('animationend', () => nextBtn.classList.remove('pulse'), { once: true });
    }, 1800);
  } else if (hint) {
    setTimeout(() => hint.classList.add('is-visible'), 1800);
  }
</script>
