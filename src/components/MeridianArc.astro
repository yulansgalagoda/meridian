---
// The Meridian Line — every dated object set along one slowly drifting rule.
// Hover pauses it; it idles when scrolled out of view.
import type { Item } from '../lib/types';

interface Props {
  items: Item[];
}

const { items } = Astro.props;

const arcItems = items
  .filter((i) => i.year !== null)
  .sort((a, b) => (a.year as number) - (b.year as number))
  .map((i) => ({ y: i.year as number, n: i.name, s: i.slug }));

const years = arcItems.map((i) => i.y);
const minYear = years.length ? Math.min(...years) : '';
const maxYear = years.length ? Math.max(...years) : '';
---

<section class="container" aria-label="Timeline of the collection">
  <div class="timeline" id="meridian-line">
    <div class="timeline__label">The Meridian Line<br />{arcItems.length} objects<br />{minYear} – {maxYear}</div>
    <div class="tl-base" aria-hidden="true"></div>
    <div class="timeline__track" id="tl-track"></div>
  </div>
</section>

<script define:vars={{ arcItems }}>
  (function () {
    const track = document.getElementById('tl-track');
    const section = document.getElementById('meridian-line');
    if (!track || !section || !arcItems.length) return;

    const SP = 205;
    const total = arcItems.length * SP;
    const START = 145; // clear the fixed label
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const fmtYear = (y) => (y < 0 ? Math.abs(y) + ' BCE' : String(y));

    const nodes = arcItems.map((it) => {
      const a = document.createElement('a');
      a.className = 'tl-item';
      a.href = '/collection/' + it.s;
      a.setAttribute('aria-label', it.n + ', ' + fmtYear(it.y));
      const name = it.n.length > 30 ? it.n.slice(0, 28).trimEnd() + '…' : it.n;
      const nm = document.createElement('span'); nm.className = 'nm'; nm.textContent = name;
      const dot = document.createElement('span'); dot.className = 'dot';
      const yr = document.createElement('span'); yr.className = 'yr'; yr.textContent = fmtYear(it.y);
      a.append(nm, dot, yr);
      track.appendChild(a);
      return a;
    });

    let off = 0, paused = false, visible = true, last = null;
    track.addEventListener('pointerenter', () => (paused = true));
    track.addEventListener('pointerleave', () => (paused = false));

    if ('IntersectionObserver' in window) {
      new IntersectionObserver((es) => { visible = es[0].isIntersecting; }, { threshold: 0 }).observe(section);
    }

    function place() {
      nodes.forEach((nd, i) => {
        const x = (((i * SP + off) % total) + total) % total;
        nd.style.left = x + START + 'px';
      });
    }
    place();

    function frame(ts) {
      if (last !== null && !paused && visible && !reduced) off -= (ts - last) * 0.013;
      last = ts;
      if (!paused && visible && !reduced) place();
      requestAnimationFrame(frame);
    }
    if (!reduced) requestAnimationFrame(frame);
  })();
</script>
