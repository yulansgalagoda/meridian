---
interface Props {
  slug: string;
}
const { slug } = Astro.props;

// SVG inner paths keyed by category slug.
// All icons share: viewBox="0 0 24 24", fill="none", stroke="currentColor",
// stroke-width="1.25", stroke-linecap="round", stroke-linejoin="round"
const icons: Record<string, string> = {

  // Open book — two pages curving from a central spine
  'books-literature': `
    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
  `,

  // Drawing dividers / compass — two legs from a pivot, cross-brace, pointed tips
  'scientific-instruments': `
    <circle cx="12" cy="4.5" r="1.5" fill="currentColor" stroke="none"/>
    <line x1="12" y1="6" x2="7.5" y2="19"/>
    <line x1="12" y1="6" x2="16.5" y2="19"/>
    <line x1="9.2" y1="13" x2="14.8" y2="13"/>
    <line x1="7.5" y1="19" x2="6.5" y2="21.5"/>
    <line x1="16.5" y1="19" x2="17.5" y2="21.5"/>
  `,

  // Folded map — three panels with fold lines
  'navigation-cartography': `
    <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
    <line x1="9" y1="3" x2="9" y2="18"/>
    <line x1="15" y1="6" x2="15" y2="21"/>
  `,

  // Vintage camera — body with bellows notch, lens circle
  'optics-photography': `
    <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
    <circle cx="12" cy="13" r="3.5"/>
    <circle cx="12" cy="13" r="1.5"/>
  `,

  // Pocket watch — round case with crown, hour/minute hands, cardinal ticks
  'horology': `
    <circle cx="12" cy="13" r="8"/>
    <line x1="12" y1="5.5" x2="12" y2="7"/>
    <line x1="12" y1="19" x2="12" y2="20.5"/>
    <line x1="4.5" y1="13" x2="6" y2="13"/>
    <line x1="18" y1="13" x2="19.5" y2="13"/>
    <line x1="12" y1="13" x2="12" y2="9.5"/>
    <line x1="12" y1="13" x2="14.5" y2="14.5"/>
    <circle cx="12" cy="13" r="0.8" fill="currentColor" stroke="none"/>
    <path d="M11 5.5h2v-2a1 1 0 0 0-2 0v2z"/>
  `,

  // Quill feather — diagonal feather with nib and barb lines
  'writing-correspondence': `
    <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/>
    <line x1="16" y1="8" x2="2" y2="22"/>
    <line x1="17.5" y1="15" x2="9" y2="15"/>
  `,

  // Classical vase — symmetric urn silhouette with mouth, neck, belly, foot
  'decorative-arts': `
    <line x1="9" y1="3" x2="15" y2="3"/>
    <path d="M9 3 C9.5 4 10 5 10 6.5 C9 8.5 6.5 11 6.5 14 C6.5 17.5 8 20 9.5 21"/>
    <path d="M15 3 C14.5 4 14 5 14 6.5 C15 8.5 17.5 11 17.5 14 C17.5 17.5 16 20 14.5 21"/>
    <line x1="9.5" y1="21" x2="14.5" y2="21"/>
    <line x1="8.5" y1="6" x2="15.5" y2="6"/>
  `,
};
---

{slug in icons && (
  <svg
    class="cat-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.25"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    set:html={icons[slug]}
  />
)}
