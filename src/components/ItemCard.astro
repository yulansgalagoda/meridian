---
import type { Item } from '../lib/types';

interface Props {
  item: Item;
  eager?: boolean;
  compact?: boolean;
}

const { item, eager = false, compact = false } = Astro.props;

function slug(s: string): string {
  return (s ?? '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const yearLabel = item.year !== null
  ? (item.year < 0 ? `${Math.abs(item.year)} BCE` : String(item.year))
  : null;

const topParts = [yearLabel || item.era || null, item.originCountry || null].filter(Boolean);
---

<a
  href={`/collection/${item.slug}`}
  class:list={['item-card reveal', compact && 'item-card--compact']}
  aria-label={item.name}
  data-name={item.name.toLowerCase()}
  data-era={slug(item.era)}
  data-category={slug(item.categoryName ?? '')}
  data-origin={slug(item.originCountry)}
  data-tag={item.tags.map(slug).join('|')}
  data-condition={slug(item.condition)}
>
  <div class="item-card__image">
    {item.primaryImage ? (
      <img src={item.primaryImage} alt={item.imageAltText || item.name} loading={eager ? 'eager' : 'lazy'} decoding="async" />
    ) : (
      <div class="item-card__placeholder">
        {yearLabel
          ? <span class="item-card__placeholder-year">{yearLabel}</span>
          : <svg class="item-card__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 15l5-5 4 4 3-3 6 6"/><circle cx="8.5" cy="8.5" r="1.5"/></svg>}
        {item.era && <span class="item-card__placeholder-era">{item.era}</span>}
      </div>
    )}
  </div>
  <div class="item-card__body">
    {topParts.length > 0 && <p class="item-card__meta-top">{topParts.join(' · ')}</p>}
    <p class="item-card__name">{item.name}</p>
    {!compact && item.shortDescription && <p class="item-card__desc">{item.shortDescription}</p>}
  </div>
</a>
